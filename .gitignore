# ============================================================
#  .gitignore — RUL Turbofan Prediction (NASA C-MAPSS FD001)
# ============================================================

# ------------------------------------------------------------
# Dataset (raw & processed) — too large for version control
# ------------------------------------------------------------
data/
processed/

# ------------------------------------------------------------
# Trained models — binary files, regenerate from notebooks
# ------------------------------------------------------------
models/
*.pkl
*.h5
*.keras
*.pt
*.pth

# ------------------------------------------------------------
# Output figures — auto-generated by notebooks
# ------------------------------------------------------------
output/

# ------------------------------------------------------------
# Python cache & compiled files
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ------------------------------------------------------------
# Virtual environments
# ------------------------------------------------------------
venv/
env/
.env/
.venv/
ENV/

# ------------------------------------------------------------
# Jupyter Notebook checkpoints
# ------------------------------------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# ------------------------------------------------------------
# IDE & editor settings
# ------------------------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.spyderproject.cfg
.spyproject/

# ------------------------------------------------------------
# OS-generated files
# ------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ------------------------------------------------------------
# Environment & secrets
# ------------------------------------------------------------
.env
.env.*
*.secret
secrets.yaml
config.local.yaml

# ------------------------------------------------------------
# Logs & profiling
# ------------------------------------------------------------
*.log
logs/
*.prof
profiling/

# ------------------------------------------------------------
# Distribution / packaging
# ------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/
pip-wheel-metadata/

# ------------------------------------------------------------
# Testing & coverage
# ------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# ------------------------------------------------------------
# TensorFlow / Keras artifacts
# ------------------------------------------------------------
tensorboard_logs/
tf_logs/
runs/

# ------------------------------------------------------------
# Temporary & misc
# ------------------------------------------------------------
*.tmp
*.bak
*.swp
*.swo
.cache/
tmp/
temp/

claude/